# BTC Leverage Trading Bot — Environment Variables
# Copy this file to .env and adjust values as needed.

# Leverage multiplier applied to each position
LEVERAGE=2

# Notional position size in USD
POSITION_SIZE_USD=100

# Stop-loss threshold as a fraction of position size (0.02 = 2%)
STOP_LOSS_PCT=0.02

# Trading strategy to use (currently only 'momentum' is supported)
STRATEGY=momentum

# Exchange mode: 'paper' (default, no credentials needed) or 'live' (not yet implemented)
EXCHANGE=paper

# Path to the JSON-lines trade log file
LOG_FILE=trades.log

# Candle interval in milliseconds (3600000 = 1 hour)
CANDLE_INTERVAL_MS=3600000
