{
    "source_app": "mas",
    "name": "mas",
    "app_name": "mas",
    "github_repo": "adobecom/mas-pinata",
    "github_app_installation_id": "122955748",
    "default_branch": "main",
    "branch_naming": "jira",
    "branch_naming_prefixes": ["MWPW"],
    "r2_bucket": "pinata-mas",
    "artifacts": {
        "specs": "r2",
        "docs": "r2",
        "kpis": "harness"
    },
    "services": [
        { "name": "aem", "env_var": "AEM_PORT", "default": 3000 },
        { "name": "studio", "env_var": "STUDIO_PORT", "default": 3100 },
        { "name": "wc", "env_var": "WC_PORT", "default": 3200 }
    ],
    "libs_service": "aem",
    "libs_param": "maslibs",
    "libs_param_value": "local",
    "depends_on": [],
    "pipeline": {
        "event_trail": true,
        "structured_prd": true,
        "progress_tracking": {
            "github": true,
            "slack": true
        }
    },
    "test_urls": {
        "envs": {
            "@mas_live": "https://main--mas-pinata--adobecom.aem.live",
            "@mas_preview": "https://main--mas-pinata--adobecom.aem.page",
            "@mas_studio_live": "https://main--mas-pinata--adobecom.aem.live/studio.html",
            "@milo_live": "https://main--milo--adobecom.aem.live",
            "@cc_live": "https://main--cc--adobecom.aem.live",
            "@adobe_prod": "https://www.adobe.com",
            "@adobe_stage": "https://www.stage.adobe.com"
        },
        "libs_param": "maslibs",
        "default_path": "/"
    },
    "verify": {
        "command": "npm run build:bundle -w web-components && npm run build -w studio",
        "after": ["build", "fix", "patch"],
        "cwd": ".",
        "timeout_seconds": 600,
        "max_attempts": 1,
        "on_failure": {
            "draft_pr": true,
            "exit_nonzero": false
        }
    },
    "review": {
        "start_recipe": "pinata-start",
        "stop_recipe": "pinata-stop"
    },
    "reviewer": {
        "domains": [
            {
                "name": "mas-pinata-workspace",
                "description": "Workspace-level conventions for mas-pinata (root configs, npm scripts, lockfile, repo-root docs) — gaps not covered by harness-bundled mas-nala / mas-studio / mas-web-components / mas-cicd domains.",
                "paths": [
                    "package.json",
                    "package-lock.json",
                    "*.md",
                    ".github/CODEOWNERS"
                ],
                "patterns": [
                    "Dependency version pins in package.json use consistent range operators per the file's existing convention; do not mix `^` and `~` ranges.",
                    "Workspace npm scripts run via `npm -w <workspace>` rather than `cd <workspace> && npm run`; cd patterns break parallel execution and break workspace dependency resolution."
                ],
                "antipatterns": [
                    "A runtime dependency in root package.json that's only used by tests — test-only deps belong in `devDependencies`.",
                    "Hardcoded contributor-specific paths (e.g. `/Users/.../`) in any committed file.",
                    "TODO comments without an owner handle or ticket reference."
                ]
            }
        ]
    }
}
